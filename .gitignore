# ─────────────────────────────────────────
#  AI-Driven BTIS Design — .gitignore
# ─────────────────────────────────────────

# ── Python ────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Virtual environments
.venv/
venv/
env/
ENV/
*.egg-info/
dist/
build/
*.egg
pip-log.txt
pip-delete-this-directory.txt

# Flask / instance folder & runtime files
instance/
*.db
*.sqlite
*.sqlite3
flask_session/
logs/
*.log

# Environment variables (keep sample files)
.env
.env.*
!.env.example

# Pytest / coverage
.pytest_cache/
.coverage
htmlcov/
.tox/
nosetests.xml
coverage.xml

# mypy / pyright / ruff
.mypy_cache/
.dmypy.json
.pytype/
.ruff_cache/

# ── Node / JavaScript / TypeScript ────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Vite build output
dist/
dist-ssr/
*.local

# TypeScript build info
*.tsbuildinfo

# ── Editors & IDEs ────────────────────────
.vscode/
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp
*.swo

# ── OS generated ──────────────────────────
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# ── Misc ──────────────────────────────────
*.bak
*.tmp
*.temp
